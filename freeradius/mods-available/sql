sql {
	dialect = "postgresql"
	driver = "rlm_sql_${dialect}"

	postgresql {
		send_application_name = yes
	}

	# Connection to existing postgres container
	radius_db = "host=postgres port=5432 dbname=radius user=radius password=radiuspass"

	# Database tables
	acct_table1 = "radacct"
	acct_table2 = "radacct"
	postauth_table = "radpostauth"
	authcheck_table = "radcheck"
	groupcheck_table = "radgroupcheck"
	authreply_table = "radreply"
	groupreply_table = "radgroupreply"
	usergroup_table = "radusergroup"

	read_groups = yes
	read_profiles = yes
	delete_stale_sessions = yes

	pool {
		start = 5
		min = 4
		max = 10
		spare = 3
		uses = 0
		retry_delay = 30
		lifetime = 0
		idle_timeout = 60
		max_retries = 5
	}

	# Read NAS clients from database
	read_clients = yes
	client_table = "nas"

	group_attribute = "SQL-Group"

	# Include PostgreSQL queries
	$INCLUDE ${modconfdir}/${.:name}/main/${dialect}/queries.conf
}
