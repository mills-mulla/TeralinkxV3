# TeralinkX V3 Environment Configuration
# Copy this file to .env and update with your production values

# Django Settings
DEBUG=False
SECRET_KEY=your-secret-key-here-change-in-production
DJANGO_SETTINGS_MODULE=teralinkx.settings

# Database Configuration
DATABASE_URL=postgres://teralinkx:justboot@localhost:5433/teralinkx
TIMESCALE_DATABASE_URL=postgres://teralinkx:justboot@localhost:5433/teralinkx

# Redis Configuration
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-email-password
DEFAULT_FROM_EMAIL=noreply@teralinkxwaves.uk

# Pusher Configuration (Optional)
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=
PUSHER_SSL=True

# RADIUS API
RADIUS_API_URL=http://radiusapi:8010/api

# Security Settings
ALLOWED_HOSTS=teralinkxwaves.uk,*.teralinkxwaves.uk,localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=https://cli.teralinkxwaves.uk,https://srv.teralinkxwaves.uk

# Monitoring
PROMETHEUS_METRICS_EXPORT_PORT=8000
GRAFANA_URL=https://mt.teralinkxwaves.uk

# Celery Workers
CELERY_WORKER_CONCURRENCY=4
CELERY_WORKER_MAX_TASKS_PER_CHILD=100

# Finance App Settings
FINANCE_ENABLE_ML_PREDICTIONS=True
FINANCE_CHURN_THRESHOLD=0.7
FINANCE_BUDGET_ALERT_THRESHOLD=0.8
FINANCE_FRAUD_SCORE_THRESHOLD=0.6

# TimescaleDB Migration
TIMESCALE_ROLLOUT_PERCENTAGE=10
TIMESCALE_ENABLED=True
